{
  "__inputs": [],
  "__requires": [],
  "title": "Orizon Routes - Services",
  "uid": "orizon-services",
  "version": 1,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Uptime",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=~\"identity-service|catalog-service|booking-service|chat-service\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "HTTP Requests /s",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=~\"identity-service|catalog-service|booking-service|chat-service\"}[5m])",
          "legendFormat": "{{job}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Request Duration (p95)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"identity-service|catalog-service|booking-service|chat-service\"}[5m])) by (le, job))",
          "legendFormat": "{{job}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Error Rate (5xx)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=~\"identity-service|catalog-service|booking-service|chat-service\", status_code=~\"5..\"}[5m])",
          "legendFormat": "{{job}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
