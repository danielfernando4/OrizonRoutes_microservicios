# FastAPI
APP_NAME=Booking Service
DEBUG=true

# Base de datos (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:pass@db_booking:5432/db_booking

# JWT (debe coincidir con Identity Service)
JWT_SECRET_KEY=super_secreto_orizon_routes_123
JWT_ALGORITHM=HS256

# PayPal Sandbox
PAYPAL_CLIENT_ID=sandbox-client-id
PAYPAL_CLIENT_SECRET=sandbox-client-secret
PAYPAL_SANDBOX=true
PAYPAL_RETURN_URL=http://localhost:15000/api/booking/confirm-payment
PAYPAL_CANCEL_URL=http://localhost:15173

# Catalog Service (URL interna en Docker)
CATALOG_SERVICE_URL=http://catalog-service:15002

# Server
HOST=0.0.0.0
PORT=8003
